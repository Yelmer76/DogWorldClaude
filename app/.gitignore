# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local SQLite dev database (re-seeded via npm run db:reset && db:migrate && db:seed)
.dev.db
.dev.db-shm
.dev.db-wal

# Cloudflare wrangler local state (Sprint 15+)
.wrangler/

# OpenNext build artifacts (regenerated by `npm run cf:build`)
.open-next/
